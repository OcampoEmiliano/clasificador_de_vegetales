{
  "expo": {
    "name": "Vegetables Classifier",
    "slug": "vegetables-classifier",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Se necesita acceso a la cámara para clasificar vegetales",
        "NSPhotoLibraryUsageDescription": "Se necesita acceso a la galería para clasificar vegetales"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-image-picker",
      "expo-asset",
      "expo-font"
    ]
  }
}
